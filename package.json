{
  "name": "mjr-ehr-interactive",
  "version": "1.0.0",
  "description": "Agentic EHR with a 9-module clinical workflow runtime",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/server.js",
    "client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node test/run-tests.js",
    "setup": "node scripts/setup.js"
  },
  "keywords": [
    "EHR",
    "ambient",
    "voice",
    "AI",
    "clinical",
    "documentation"
  ],
  "author": "MJR Health Systems",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.263.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.0",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "vite": "^6.4.2"
  },
  "overrides": {
    "brace-expansion": ">=1.1.13",
    "minimatch": ">=3.1.4",
    "path-to-regexp": ">=1.9.0",
    "picomatch": ">=2.3.2",
    "rollup": ">=4.59.0",
    "esbuild": ">=0.25.0"
  }
