# ==========================================
# Agentic EHR Environment Configuration
# ==========================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.

# ---- Node Environment ----
NODE_ENV=development
# Set to 'production' for live deployments

# ---- Server ----
PORT=3000
HOST=0.0.0.0

# ---- Database ----
DATABASE_PATH=./data/mjr-ehr.db
# For PostgreSQL (future): DATABASE_URL=postgresql://user:pass@host:5432/ehr_db

# ---- Authentication ----
# REQUIRED in production. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRY=8h
REFRESH_TOKEN_EXPIRY=7d

# ---- PHI Encryption ----
# REQUIRED. AES-256-GCM key for encrypting patient data at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PHI_ENCRYPTION_KEY=

# ---- CORS ----
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173

# ---- Provider ----
# Display name used in SOAP notes and CDS suggestions when req.user is unavailable
PROVIDER_NAME=Dr. Provider

# ---- AI / Claude API ----
ANTHROPIC_API_KEY=
# Leave blank to use pattern-matching fallback (no API calls)
AI_MODE=mock
# Set to 'api' (with ANTHROPIC_API_KEY) to enable Claude-powered clinical extraction

# ---- LabCorp Integration (Phase 2b/2c) ----
# Mode controls how the LabCorp client behaves:
#   mock  — reads fixtures from server/integrations/labcorp/mock-responses/ (no network)
#   api   — hits the real sandbox URL using OAuth2 tokens stored per-user
LABCORP_MODE=mock

# Client credentials issued by the LabCorp developer portal. Leave blank in mock mode.
# Treat LABCORP_CLIENT_SECRET as a secret of equal sensitivity to JWT_SECRET.
LABCORP_CLIENT_ID=
LABCORP_CLIENT_SECRET=

# OAuth2 authorization + token endpoints. The sandbox and prod portals publish
# these separately — always keep LABCORP_PROD_URL commented out until you've
# completed a full sandbox handoff.
LABCORP_AUTH_URL=
LABCORP_TOKEN_URL=
# LABCORP_SCOPE is the space-delimited OAuth2 scope string. The default below
# matches what the /oauth/start route falls back to.
LABCORP_SCOPE=lab.read lab.write

# Redirect URI MUST exactly match the value registered in the developer portal.
# For local dev, use http://localhost:3000/api/integrations/labcorp/oauth/callback
LABCORP_REDIRECT_URI=http://localhost:3000/api/integrations/labcorp/oauth/callback

# Base URL for lab order/result calls. Sandbox is safe; prod is intentionally
# commented out so you can't ship it by accident.
LABCORP_SANDBOX_URL=
# LABCORP_PROD_URL=  (DO NOT UNCOMMENT — production hits real patient data)

# Timeout for each outbound LabCorp HTTPS call (milliseconds). Matches AI client.
LABCORP_TIMEOUT_MS=30000

# ---- Scheduling ----
# Front-desk agent scheduling backend:
#   mock — generates synthetic provider availability and stores appointments in memory
#          (default; what every existing scenario test runs against)
#   db   — persists appointments to the SQLite `appointments` table and queries
#          real provider availability against booked rows
SCHEDULER_MODE=mock

# ---- Patient Notifications (TODO — not yet implemented) ----
# When email/SMS notification delivery is added in a future PR, configure here.
# Today the front-desk agent reports `channels: ['portal']` and explicitly
# flags email/sms as `not_configured`. Do NOT enable these without first
# wiring the corresponding integrations and confirming HIPAA BAAs.
# SENDGRID_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=150

# ---- Logging ----
LOG_LEVEL=info
# Options: fatal, error, warn, info, debug, trace

# ---- TLS (production) ----
# TLS_CERT_PATH=/etc/ssl/certs/ehr.crt
# TLS_KEY_PATH=/etc/ssl/private/ehr.key

# ---- Backup ----
# BACKUP_DIR=./backups
# BACKUP_RETENTION_DAYS=30
# BACKUP_S3_BUCKET=
